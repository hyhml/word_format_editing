{
  "metadata": {
    "name": "通用公文格式示例",
    "description": "把本文件复制成自己的规格文件后修改。生成器会根据此规格产出独立的 Word 格式化脚本。"
  },
  "page": {
    "size": "A4",
    "orientation": "portrait",
    "margins_cm": {
      "top": 2.54,
      "bottom": 2.54,
      "left": 3.18,
      "right": 3.18
    }
  },
  "default": {
    "font_name": "Times New Roman",
    "east_asia_font_name": "宋体",
    "font_size_pt": 12,
    "bold": false,
    "italic": false,
    "alignment": "justify",
    "line_spacing": 1.5,
    "first_line_indent_cm": 0.74,
    "space_before_pt": 0,
    "space_after_pt": 0
  },
  "rules": [
    {
      "name": "封面或正文标题",
      "match": {
        "paragraph_index": 0
      },
      "format": {
        "font_name": "Times New Roman",
        "east_asia_font_name": "黑体",
        "font_size_pt": 22,
        "bold": true,
        "alignment": "center",
        "line_spacing": 1.5,
        "first_line_indent_cm": 0,
        "space_before_pt": 0,
        "space_after_pt": 18
      }
    },
    {
      "name": "一级标题",
      "match": {
        "regex": "^(第[一二三四五六七八九十百]+[章节]|[一二三四五六七八九十]+、|\\d+\\s+)"
      },
      "format": {
        "east_asia_font_name": "黑体",
        "font_size_pt": 16,
        "bold": true,
        "alignment": "left",
        "line_spacing": 1.5,
        "first_line_indent_cm": 0,
        "space_before_pt": 12,
        "space_after_pt": 6
      }
    },
    {
      "name": "二级标题",
      "match": {
        "regex": "^(\\d+\\.\\d+|（[一二三四五六七八九十]+）)"
      },
      "format": {
        "east_asia_font_name": "楷体",
        "font_size_pt": 14,
        "bold": true,
        "alignment": "left",
        "line_spacing": 1.5,
        "first_line_indent_cm": 0,
        "space_before_pt": 6,
        "space_after_pt": 6
      }
    }
  ],
  "tables": {
    "enabled": true,
    "font_name": "Times New Roman",
    "east_asia_font_name": "宋体",
    "font_size_pt": 10.5,
    "bold_header_row": true,
    "alignment": "center",
    "cell_vertical_alignment": "center"
  }
}
